# Keep this file as an example. Copy it to .env and paste your own keys.
SECRET_KEY=change-this-secret-key
THREAT_INTEL_ENABLED=true
VIRUSTOTAL_API_KEY=PASTE_YOUR_VIRUSTOTAL_API_KEY_HERE
HYBRID_ANALYSIS_API_KEY=PASTE_YOUR_HYBRID_ANALYSIS_API_KEY_HERE
MAX_API_IOCS_PER_TYPE=8
API_TIMEOUT_SECONDS=15
API_RETRY_COUNT=2
API_CACHE_TTL_SECONDS=86400

# Disabled by default because sandbox submission uploads evidence to a third-party service.
HA_AUTO_SUBMIT=false
HA_ENVIRONMENT_ID=160
HA_MAX_SUBMIT_BYTES=33554432

ALERT_WEBHOOK_URL=
